generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
}

model User {
  id      String   @id @default(auto()) @map("_id") @db.ObjectId
  email   String   @unique
  uploads Upload[]
}

model Upload {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  imageUrl    String
  sportName   String
  description String
  createdAt   DateTime @default(now())
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
}